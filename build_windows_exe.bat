@echo off
:: =====================================================================
:: SP-DX-License-Identifier: Apache-2.0
:: Maqarr Desk - Windows Native Offline EXE Builder
:: =====================================================================
chcp 65001 > nul
title مجمع بناء تطبيق مقر ديسك - Windows EXE Builder

echo =======================================================================
echo   مقر ديسك - معالج بناء البرنامج المستقل لويندوز (Windows EXE Builder)
echo =======================================================================
echo.
echo سيقوم هذا الملف التلقائي بتهيئة البيئة وبناء ملف التشغيل المستقل (.exe) 
echo ليتم تشغيله بالكامل دون الحاجة للاتصال بالإنترنت بشكل آمن وأوفلاين.
echo.
echo -----------------------------------------------------------------------
echo [1/4] التحقق من المتطلبات الأساسية للنظام...
echo -----------------------------------------------------------------------

:: Check Node.js
where node >nul 2>nul
if %errorlevel% neq 0 (
    echo [خطأ] لم يتم العثور على Node.js على جهازك!
    echo يرجى تحميله وتثبيته أولاً من: https://nodejs.org
    echo ثم أعد تشغيل هذا المعالج بعد التثبيت.
    echo.
    pause
    exit /b
) else (
    echo [موافق] تم العثور على بيئة Node.js بنجاح.
)

:: Check Rust and Cargo
where cargo >nul 2>nul
if %errorlevel% neq 0 (
    echo [تنبيه] لم يتم العثور على لغة Rust (cargo) على جهازك!
    echo تطبيق مقر ديسك مبني بتقنيات فائقة الأمان باستخدام Rust + Tauri.
    echo.
    echo لتثبيت Rust والتحويل إلى EXE مستقل، يرجى القيام بـ:
    echo 1. تثبيت أدوات بناء C++ من مايكروسوفت (C++ Build Tools).
    echo 2. تثبيت Rust عبر الرابط الرسمي: https://rustup.rs
    echo.
    echo هل تريد محاولة المتابعة والتحقق على أية حال؟ (نعم/لا)
    set /p "user_choice=اكتب اختيارك واضغط Enter: "
    if /i "%user_choice%" neq "نعم" (
        exit /b
    )
) else (
    echo [موافق] تم العثور على بيئة لغة البرمجة Rust بنجاح.
)

echo.
echo -----------------------------------------------------------------------
echo [2/4] تثبيت حزم البرمجة والاعتماديات الخاصة بالواجهة...
echo -----------------------------------------------------------------------
echo يرجى الانتظار، يتم الآن تثبيت المكتبات (npm install)...
call npm install
if %errorlevel% neq 0 (
    echo [خطأ] فشل تثبيت مكتبات وتوابع المشروع. يرجى التحقق من اتصالك بالإنترنت أثناء البناء الأول.
    pause
    exit /b
)
echo [موافق] تم تثبيت المكتبات المساعدة بنجاح.

echo.
echo -----------------------------------------------------------------------
echo [3/4] بناء واجهة الويب وملفات الضغط (React + Vite)...
echo -----------------------------------------------------------------------
echo جاري معالجة الكود وبناء النسخة المحسنة والأوفلاين...
call npm run build
if %errorlevel% neq 0 (
    echo [خطأ] فشل في بناء واجهة React. يرجى مراجعة الكود البرمجي.
    pause
    exit /b
)
echo [موافق] تم بناء الواجهة وحفظها في مجلد dist بنجاح.

echo.
echo -----------------------------------------------------------------------
echo [4/4] إنتاج ملف التشغيل والبرنامج المستقل وحزم التثبيت (Tauri Build)...
echo -----------------------------------------------------------------------
echo جاري الكبس والتجميع الآن لإنتاج ملف EXE... قد يستغرق هذا بضع دقائق في المرة الأولى...
call npm run tauri build
if %errorlevel% neq 0 (
    echo [خطأ] فشل Tauri في إنتاج الملف الثنائي المستقل.
    echo تأكد من تثبيت Rust وأدوات Windows SDK / Build Tools بشكل صحيح على جهازك.
    echo للمزيد من التفاصيل، يرجى مراجعة ملف BUILD_OFFLINE_EXE.md المرفق.
    pause
    exit /b
)

echo.
echo =======================================================================
echo 🎉 تهانينا! تم بناء برنامج "مقر ديسك" بنجاح كلحظة واحدة مستدامة!
echo =======================================================================
echo ستجد ملف التثبيت والـ EXE المستقل في المسار التالي:
echo \src-tauri\target\release\bundle\msi\
echo أو ملف التشغيل المباشر في المسار:
echo \src-tauri\target\release\
echo.
echo شكراً لاستخدامك نكسيس لخدمات حجز المساحات الآمنة أوفلاين.
pause
